# ============================================================
# 秘密情報（gitに入れない。サーバーには手動で設置すること）
# ============================================================
# APIキーとDB接続情報。これが無いとPostgreSQLに繋がらないので
# デプロイ時に必ずサーバーへ手動コピーする（CLAUDE.md 参照）
config.json


# ============================================================
# ⚠️ migrations/ は絶対に除外しないこと
# ------------------------------------------------------------
# migrations を gitignore すると、サーバー側で manage.py migrate を
# しても テーブルが作られず「テーブルが無い / カラムが無い」という
# DB不整合エラーになる。よくある事故なので、ここに明記しておく。
#   例）*/migrations/* のような行を足してはいけない
# ============================================================


# ============================================================
# Python
# ============================================================
venv/
__pycache__/
*.py[cod]
*.egg-info/


# ============================================================
# Django
# ============================================================
# 旧SQLite（PostgreSQL移行前のバックアップ）。
# サーバーに持ち込むと誤って参照される恐れがあるので必ず除外する
db.sqlite3
db.sqlite3-journal

# ユーザーがアップロードした画像（銘柄カルテの経営陣写真）。
# 実データなのでgit管理せず、サーバー側で永続ディレクトリを用意する
/media/

# collectstatic の出力先。
# ※ BoatRaceSite では staticfiles/ をコミットして配信する運用のため、
#   同じ方式を採るならこの行はコメントアウトしたままにしておく
# /staticfiles/

*.log


# ============================================================
# エディタ・OS
# ============================================================
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Claude Code のローカル設定（端末固有のため共有しない）
.claude/settings.local.json
